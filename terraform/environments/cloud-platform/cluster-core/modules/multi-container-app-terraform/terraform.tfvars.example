# Example Terraform variables file
# Copy this to terraform.tfvars and customize for your deployment

# Namespace configuration
namespace = "multi-container-app-demo"

# Content API configuration
content_api_image_repository = "ministryofjustice/cloud-platform-multi-container-demo-app"
content_api_image_tag        = "content-api-1.6"
content_api_replicas         = 1

# Rails App configuration
rails_app_image_repository = "ministryofjustice/cloud-platform-multi-container-demo-app"
rails_app_image_tag        = "rails-app-1.6"
rails_app_replicas         = 1

# Worker configuration
worker_image_repository = "ministryofjustice/cloud-platform-multi-container-demo-app"
worker_image_tag        = "worker-1.6"
worker_replicas         = 1

# Database configuration
# Option 1: Deploy PostgreSQL with the app (like Helm chart)
deploy_postgresql      = true
postgres_database      = "multi_container_demo_app"
postgres_username      = "postgres"
postgres_password      = "changeme123"
create_database_secret = true

# Option 2: Use external database (comment out lines above and uncomment below)
# deploy_postgresql      = false
# create_database_secret = true
# database_url           = "postgresql://username:password@external-host:5432/database_name"

content_api_url = "http://content-api-service:4567/image_url.json"

# HTTPRoute configuration (for external access)
enable_httproute      = true
listenerset_name      = "default-listenerset"
listenerset_namespace = "envoy-gateway-system"
hostnames = [
  "my-app.apps.live.cloud-platform.service.justice.gov.uk"
]

# Migrations
enable_migrations = true
