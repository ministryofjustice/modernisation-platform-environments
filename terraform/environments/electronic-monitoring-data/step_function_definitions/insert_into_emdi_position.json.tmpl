{
  "StartAt": "ProcessDates",
  "States": {
    "ProcessDates": {
      "Type": "Map",
      "ItemsPath": "$.filter_dates",
      "MaxConcurrency": 1,
      "ItemSelector": {
        "filter_date.$": "$$.Map.Item.Value",
        "input.$": "$"
      },
      "Iterator": {
        "StartAt": "MergeIntoEmdiPosition",
        "States": {
          "MergeIntoEmdiPosition": {
            "Type": "Task",
            "Resource": "arn:aws:states:::lambda:invoke",
            "OutputPath": "$.Payload",
            "Parameters": {
              "FunctionName": "${merge_emdi_position}",
              "Payload": {
                "resource": "/request/",
                "path": "/request/",
                "httpMethod": "POST",
                "headers": {
                  "Content-Type": "application/json"
                },
                "multiValueHeaders": {},
                "queryStringParameters": null,
                "requestContext": {
                  "resourcePath": "/request/",
                  "httpMethod": "POST",
                  "path": "/request/",
                  "identity": {
                    "sourceIp": "127.0.0.1"
                  }
                },
                "isBase64Encoded": false,
                "body.$": "States.JsonToString($)"
              }
            },
            "End": true
          }
        }
      },
      "End": true
    }
  }
}
