          "refId": "A",
          "region": "eu-west-2",
          "namespace": "AWS/NATGateway",
          "queryMode": "Metrics",
          "metricQueryType": 1,
          "metricEditorMode": 1,
          "sqlExpression": "SELECT AVG(ActiveConnectionCount) FROM SCHEMA(\"AWS/NATGateway\", NatGatewayId) GROUP BY NatGatewayId ORDER BY AVG() DESC"
        }
