      "id": 1,
      "type": "text",
      "title": "About this dashboard",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "EKS health for a single Data Platform account, using CloudWatch Container Insights. Choose an Account and Cluster at the top. This dashboard is intended as a first-look cluster health view: node readiness, resource pressure, pod health, restarts and related ALB health. It helps identify whether an issue is cluster-level, node-level, namespace-level or ingress-related. Detailed workload, application and networking views should live in separate deep-dive dashboards."
      }
    },
    { "id": 2, "type": "row", "title": "At a glance", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 }, "panels": [] },
    {
      "id": 3,
      "type": "stat",
      "title": "Nodes",
      "datasource": { "type": "cloudwatch", "uid": "${account}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "cloudwatch", "uid": "${account}" }, "refId": "A", "region": "eu-west-2", "namespace": "ContainerInsights", "queryMode": "Metrics", "metricQueryType": 1, "metricEditorMode": 1, "sqlExpression": "SELECT MAX(cluster_node_count) FROM \"ContainerInsights\" WHERE ClusterName = '${cluster}'" }
      ]
    },
    {
      "id": 4,
