    {
      "id": 1,
      "type": "text",
      "title": "About this dashboard",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": { "mode": "markdown", "content": "Landing overview for a single Data Platform account, built from auto-published CloudWatch metrics (no agents or setup needed). Pick an **Account** at the top to switch between the per-account CloudWatch data sources. The **At a glance** tiles summarise the selected time window; the rows below break down Lambda (compute), RDS (databases) and SQS (messaging). Service deep-dives live in the other folders — Kubernetes, Networking and Databases. Panels use CloudWatch Metrics Insights so they keep working as resources come and go; extend this by dropping a JSON file into `src/helm/dashboards/platform/`. Glue, Athena and S3 storage can be added the same way." }
    },
    { "id": 2, "type": "row", "title": "At a glance", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 }, "panels": [] },
    {
      "id": 3,
      "type": "stat",
      "title": "Lambda invocations",
      "datasource": { "type": "cloudwatch", "uid": "${account}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "cloudwatch", "uid": "${account}" }, "refId": "A", "region": "eu-west-2", "namespace": "AWS/Lambda", "queryMode": "Metrics", "metricQueryType": 1, "metricEditorMode": 1, "sqlExpression": "SELECT SUM(Invocations) FROM \"AWS/Lambda\"" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Lambda errors",
      "datasource": { "type": "cloudwatch", "uid": "${account}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "cloudwatch", "uid": "${account}" }, "refId": "A", "region": "eu-west-2", "namespace": "AWS/Lambda", "queryMode": "Metrics", "metricQueryType": 1, "metricEditorMode": 1, "sqlExpression": "SELECT SUM(Errors) FROM \"AWS/Lambda\"" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Lambda throttles",
      "datasource": { "type": "cloudwatch", "uid": "${account}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 5 },
