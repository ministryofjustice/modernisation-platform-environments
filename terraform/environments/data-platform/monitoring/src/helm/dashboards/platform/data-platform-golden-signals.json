    {
      "id": 1,
      "type": "text",
      "title": "About this dashboard",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": { "mode": "markdown", "content": "This dashboard provides a curated view of the four golden signals — latency, traffic, errors and saturation — across key shared AWS services in a single Data Platform account. It is intended as a first-look reliability dashboard, helping engineers quickly identify whether issues are related to load balancers, Lambda, RDS or NAT Gateway. Pick an Account at the top. Detailed service-specific dashboards live in the Kubernetes, Databases, Networking and Platform folders." }
    },
    { "id": 2, "type": "row", "title": "At a glance", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 }, "panels": [] },
    {
      "id": 3,
      "type": "stat",
      "title": "ALB target 5xx",
      "description": "ALB 5xx responses generated by your backend targets (not the load balancer itself) — indicates application or backend errors.",
      "datasource": { "type": "cloudwatch", "uid": "${account}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "cloudwatch", "uid": "${account}" }, "refId": "A", "region": "eu-west-2", "namespace": "AWS/ApplicationELB", "queryMode": "Metrics", "metricQueryType": 1, "metricEditorMode": 1, "sqlExpression": "SELECT SUM(HTTPCode_Target_5XX_Count) FROM \"AWS/ApplicationELB\"" }
      ]
    },
    {
