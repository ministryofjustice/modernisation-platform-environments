          "queryMode": "Metrics",
          "metricQueryType": 1,
          "metricEditorMode": 1,
          "sqlExpression": "SELECT AVG(ReadLatency) FROM SCHEMA(\"AWS/RDS\", DBInstanceIdentifier) GROUP BY DBInstanceIdentifier ORDER BY AVG() DESC"
