    {
      "id": 1,
      "type": "text",
      "title": "About this dashboard",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "The four **golden signals** (latency, traffic, errors, saturation) curated across the key shared services in a single Data Platform account: ALB, Lambda, RDS and NAT. Pick an **Account** at the top. A single per-service dropdown is not practical here because each CloudWatch namespace uses different metric names — so this is a curated overview, and per-service deep-dives live in their own folders (Kubernetes, Databases, Networking, Platform)."
      }
    },
    {
      "id": 2,
      "type": "row",
      "title": "Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 },
      "panels": []
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "ALB target response time",
      "datasource": { "type": "cloudwatch", "uid": "${account}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "min": 0,
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${account}" },
          "refId": "A",
          "region": "eu-west-2",
          "namespace": "AWS/ApplicationELB",
          "queryMode": "Metrics",
          "metricQueryType": 1,
          "metricEditorMode": 1,
          "sqlExpression": "SELECT AVG(TargetResponseTime) FROM SCHEMA(\"AWS/ApplicationELB\", LoadBalancer) GROUP BY LoadBalancer ORDER BY AVG() DESC"
        }
      ]
    },
    {
      "id": 4,
