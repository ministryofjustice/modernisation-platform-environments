  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "About this dashboard",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "Database health for a single Data Platform account, from auto-published CloudWatch metrics. Pick an **Account** at the top. Covers RDS/Aurora, Redshift, OpenSearch and DynamoDB — empty panels simply mean that engine is not used in the selected account."
      }
    },
    {
      "id": 2,
      "type": "row",
      "title": "RDS / Aurora",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 },
      "panels": []
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU utilisation by instance",
      "datasource": { "type": "cloudwatch", "uid": "${account}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "cloudwatch", "uid": "${account}" },
          "refId": "A",
          "region": "eu-west-2",
          "namespace": "AWS/RDS",
          "queryMode": "Metrics",
          "metricQueryType": 1,
          "metricEditorMode": 1,
          "sqlExpression": "SELECT AVG(CPUUtilization) FROM SCHEMA(\"AWS/RDS\", DBInstanceIdentifier) GROUP BY DBInstanceIdentifier ORDER BY AVG() DESC"
        }
      ]
    },
