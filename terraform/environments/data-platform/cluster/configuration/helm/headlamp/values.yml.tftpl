---
tolerations:
  - operator: Exists
    effect: NoSchedule
  - operator: Exists
    effect: NoExecute

serviceAccount:
  create: true
  name: ${service_account_name}

clusterRoleBinding:
  create: true
  clusterRoleName: ${cluster_role_name}

config:
  pluginsDir: /headlamp/plugins

ingress:
  enabled: false

httpRoute:
  enabled: true
  parentRefs:
    - name: ${gateway_name}
      namespace: ${gateway_namespace}
  hostNames: headlamp.${gateway_hostname}