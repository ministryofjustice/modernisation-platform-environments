meta {
  name: Get Multipart Part URLs
  type: http
  seq: 5
}

post {
  url: {{api_endpoint}}/transfer-tickets/{{transfer_ticket}}/parts
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{bearer_token}}
}

body:json {
  {
    "partNumberStart": 2,
    "partNumberEnd": 3
  }
}
