meta {
  name: Complete Multipart Upload
  type: http
  seq: 6
}

post {
  url: {{api_endpoint}}/transfer-tickets/{{transfer_ticket}}/complete
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{bearer_token}}
}

body:json {
  {
    "parts": [
      {
        "partNumber": 1,
        "eTag": "\"replace-with-uploaded-part-etag\""
      }
    ]
  }
}
